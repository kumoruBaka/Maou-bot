# Discord Bot Token (wajib)
TOKEN=isi_token_bot_disini

# Discord Application/Client ID (wajib untuk slash commands)
# Bisa dilihat di https://discord.com/developers/applications → General Information
CLIENT_ID=isi_client_id_disini

# Guild ID untuk development (opsional)
# Bila diisi, slash commands hanya didaftarkan ke server ini (update instan).
# Kosongkan untuk deploy global (propagasi ~1 jam).
GUILD_ID=

# YouTube Data API v3 Key (wajib untuk fitur auto-play)
# Buat di https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=isi_youtube_api_key_disini

# Prefix untuk prefix commands (default: mao.)
PREFIX=mao.

# Discord Webhook URL untuk notifikasi server join/leave (opsional)
WEBHOOK_URL=
